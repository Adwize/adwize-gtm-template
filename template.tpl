___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const copyFromDataLayer = require('copyFromDataLayer');
const copyFromWindow = require('copyFromWindow');
const encodeUriComponent = require('encodeUriComponent');
const getContainerVersion = require('getContainerVersion');
const getTimestampMillis = require('getTimestampMillis');
const JSON = require('JSON');
const sendPixel = require('sendPixel');
const getUrl = require('getUrl');
const log = require('logToConsole');

// =============================================================================
// CONFIGURATION
// =============================================================================

const ENDPOINT = 'https://api.getadwize.com/api/v1/events/collect';
const apiKey = data.apiKey;
const triggerMode = data.triggerMode || 'all';
const customEvents = data.customEvents || '';
const captureDataLayer = data.captureDataLayer || false;
const captureEcommerceItems = data.captureEcommerceItems !== false;
const debugMode = data.debugMode || false;

const ecommerceEvents = [
  'purchase', 'transaction', 'add_to_cart', 'remove_from_cart',
  'begin_checkout', 'add_payment_info', 'add_shipping_info',
  'view_item', 'view_item_list', 'select_item', 'view_cart',
  'add_to_wishlist', 'refund'
];

// =============================================================================
// HELPERS
// =============================================================================

const debugLog = function(message, payload) {
  if (debugMode) {
    log('[Adwize] ' + message, payload);
  }
};

const shouldCaptureEvent = function(eventName) {
  if (!eventName) return false;

  if (triggerMode === 'all') return true;

  if (triggerMode === 'ecommerce') {
    return ecommerceEvents.indexOf(eventName) !== -1;
  }

  if (triggerMode === 'custom' && customEvents) {
    const eventList = customEvents.split(',');
    for (var i = 0; i < eventList.length; i++) {
      if (eventList[i].trim() === eventName) return true;
    }
    return false;
  }

  return false;
};

const getEcommerceData = function() {
  if (!captureEcommerceItems) return null;

  const ecommerce = copyFromDataLayer('ecommerce');
  if (ecommerce) return ecommerce;

  const items = copyFromDataLayer('items');
  if (items) return {items: items};

  return null;
};


// =============================================================================
// MAIN LOGIC
// =============================================================================

const eventName = copyFromDataLayer('event');
const timestamp = getTimestampMillis();
const cv = getContainerVersion();
const pageUrl = getUrl('href');

if (!shouldCaptureEvent(eventName)) {
  debugLog('Skipping event (not in capture list): ' + eventName);
  data.gtmOnSuccess();
  return;
}

var ecommerceData = getEcommerceData();
var fullDataLayer = captureDataLayer ? copyFromWindow('dataLayer') : null;

var eventDataObj = {
  event: eventName
};

if (ecommerceData) {
  eventDataObj.ecommerce = ecommerceData;
}

var transactionId = copyFromDataLayer('transaction_id') || copyFromDataLayer('transactionId');
var value = copyFromDataLayer('value');
var currency = copyFromDataLayer('currency');

if (transactionId) eventDataObj.transaction_id = transactionId;
if (value !== undefined) eventDataObj.value = value;
if (currency) eventDataObj.currency = currency;

if (fullDataLayer) {
  eventDataObj.dataLayer = fullDataLayer;
}

var payload = {
  source: 'gtm',
  source_id: cv.containerId,
  events: [{
    type: eventName,
    timestamp: timestamp,
    data: eventDataObj,
    metadata: {
      container_id: cv.containerId,
      container_version: cv.version,
      environment: cv.environmentName || 'live',
      page_url: pageUrl
    }
  }]
};

debugLog('Sending payload:', payload);

var jsonStr = JSON.stringify(payload);
var url = ENDPOINT + '?k=' + encodeUriComponent(apiKey) + '&d=' + encodeUriComponent(jsonStr);

sendPixel(url, function() {
  debugLog('Event sent successfully: ' + eventName);
}, function() {
  debugLog('Failed to send event: ' + eventName);
});

data.gtmOnSuccess();


